# Optional Open-Meteo customer endpoint for commercial use.
# The public non-commercial prototype uses the defaults when these are empty.
VITE_GEOCODING_API_URL=
VITE_GEOCODING_API_KEY=

# VITE_* values are public in the browser bundle. Never place a private server secret here.

# Optional v1.1 Google Calendar gateway. These values are read only by server/index.mjs.
# Never prefix private values with VITE_ and never commit real credentials.
ATLASTIME_APP_ORIGIN=http://localhost:4173
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4173/api/google-calendar/callback
# Generate a unique 32-byte base64url key for each environment.
GOOGLE_TOKEN_ENCRYPTION_KEY=
